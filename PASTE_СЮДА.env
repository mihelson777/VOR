# ============================================================
# ВСТАВЬ СЮДА СВОЙ API КЛЮЧ — затем переименуй файл в .env
# ============================================================
# 1. Получи ключ: https://console.groq.com/keys (Groq, бесплатно)
# 2. Вставь ниже вместо ВСТАВЬ_КЛЮЧ_СЮДА
# 3. Переименуй этот файл: PASTE_СЮДА.env → .env
# 4. Перезапусти web_server.py или telegram_bot.py
# ============================================================

GROQ_API_KEY=ВСТАВЬ_КЛЮЧ_СЮДА

# Пароль для веб-интерфейса (по умолчанию vor)
WEB_PASSWORD=vor
