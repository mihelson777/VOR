# API ключи — скопируй в .env и вставь свои значения
# НИКОГДА не коммить .env в git!

# Groq (бесплатно, без карты) — рекомендуется
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter (бесплатные модели через один ключ)
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (платно)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Модель по умолчанию (если не задана)
# OUROBOROS_MODEL=llama-3.3-70b-versatile

# Бюджет в USD (опционально)
# TOTAL_BUDGET=10

# Telegram (для telegram_bot.py)
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_ALLOWED_USERS=123456789,987654321
# TELEGRAM_OWNER_CHAT_ID=123456789  # For background consciousness (get via @userinfobot)
# TELEGRAM_WEBHOOK_URL=https://yourdomain.com
# TELEGRAM_WEBHOOK_PORT=8443

# Web UI (web_server.py)
# WEB_PASSWORD=vor

# Voice (Phase 7)
# VOICE_SPEED=180
# VOICE_VOLUME=1.0
# VOICE_TTS_ENABLED=false   # headless server — pyttsx3 не работает
# WEB_PORT=8001
# WEB_SECRET_KEY=change_me_to_random_string
